# ================================================================
# AstralFox 星尘 — Backend Configuration
# ================================================================
# 使用方法: 复制此文件为 .env，然后填入你的 API Key
#   cp .env.example .env
#
# 不填 Key 也可以运行，缺失的服务会自动降级为 mock 模式。
# ================================================================

# ── Azure Speech Services (语音识别 ASR + 可选 TTS) ───────────────
# 获取地址: https://portal.azure.com → 创建"语音服务"资源 → 密钥管理
# 免费层(F0): 每月 5 小时语音识别，够桌面宠物用
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastasia
# 识别语言: zh-CN(中文), en-US(英文), ja-JP(日文)
ASR_LANGUAGE=zh-CN

# ── OpenAI API (大语言模型 LLM) ───────────────────────────────────
# 获取地址: https://platform.openai.com/api-keys
# 如果用第三方代理/中转 API（如 Azure OpenAI, DeepSeek 等），
# 修改 OPENAI_BASE_URL 为代理地址
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=

# ── TTS 语音合成 ──────────────────────────────────────────────────
# azure = Azure TTS (收费，需填 AZURE_SPEECH_KEY，音质最好)
# edge  = edge-tts (免费，无需 Key，调用微软 Edge 公开接口)
TTS_PROVIDER=edge
# 发音人: zh-CN-XiaoxiaoNeural(中文女声-活泼),
#         zh-CN-YunxiNeural(中文男声-温柔),
#         zh-CN-XiaoyiNeural(中文女声-可爱)
TTS_VOICE=zh-CN-XiaoxiaoNeural
TTS_RATE=+0%

# ── 服务器 ────────────────────────────────────────────────────────
SERVER_HOST=0.0.0.0
SERVER_PORT=8765

# ── 和风天气 API (Function Tool: 天气查询) ────────────────────────
# 获取地址: https://dev.qweather.com/ → 注册 → 控制台创建应用
# 免费版: 每天 1000 次调用，够桌面宠物日常使用
QWEATHER_API_KEY=

# ── Bing Search API (Function Tool: 网页搜索) ─────────────────────
# 获取地址: https://portal.azure.com → 创建 Bing Search v7 资源
# 免费层: 每月 1000 次搜索
BING_SEARCH_API_KEY=

# ── ffmpeg (TTS 音频格式转换，可选) ───────────────────────────────
# 下载: https://ffmpeg.org/download.html
# 安装后将 bin 目录加入系统 PATH，或取消下面注释填绝对路径
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# 没有 ffmpeg 时 TTS 会自动降级为静音 mock
