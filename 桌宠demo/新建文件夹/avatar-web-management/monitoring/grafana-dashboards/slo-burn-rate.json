{
  "title": "Avatar Web — SLO / Burn Rate",
  "uid": "avatar-web-slo",
  "tags": ["avatar-web", "slo", "burn-rate"],
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Error Budget Remaining (%)",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [
        {
          "expr": "slo:error_budget:remaining_pct",
          "legendFormat": "Budget %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "orange", "value": 5 },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 2,
      "title": "Availability Burn Rate (5m)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 6 },
      "targets": [
        {
          "expr": "slo:burn_rate:ratio5m",
          "legendFormat": "Availability burn rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 2 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 3,
      "title": "P95 Latency (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(avatar_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(avatar_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Latency Burn Rate (5m)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "slo:latency_burn_rate:ratio5m",
          "legendFormat": "Latency burn rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 6 },
              { "color": "red", "value": 14.4 }
            ]
          },
          "unit": "none"
        }
      }
    },
    {
      "id": 5,
      "title": "5xx Error Rate (5m avg)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(avatar_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(avatar_http_requests_total[5m]))",
          "legendFormat": "Error rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit" }
      }
    },
    {
      "id": 6,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum(rate(avatar_http_requests_total[1m]))",
          "legendFormat": "Total req/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 7,
      "title": "Active Alerts (SLO)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 20, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "ALERTS{component=\"slo\", alertstate=\"firing\"}",
          "legendFormat": "Firing"
        }
      ]
    },
    {
      "id": 8,
      "title": "Error Rate by Route (top 5)",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 20, "w": 18, "h": 4 },
      "targets": [
        {
          "expr": "topk(5, sum(rate(avatar_http_requests_total{status_code=~\"5..\"}[5m])) by (route))",
          "legendFormat": "{{ route }}"
        }
      ]
    }
  ]
}
