{
  "title": "Avatar Web — Cache",
  "uid": "avatar-web-cache",
  "tags": ["avatar-web", "cache", "redis"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1, "title": "Cache Hit Rate", "type": "graph",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(avatar_cache_hits_total[1m])) by (cache_type) / (sum(rate(avatar_cache_hits_total[1m])) by (cache_type) + sum(rate(avatar_cache_misses_total[1m])) by (cache_type))",
          "legendFormat": "{{cache_type}}"
        }
      ],
      "yaxes": [{ "format": "percentunit", "min": 0, "max": 1 }],
      "thresholds": [{ "value": 0.5, "color": "red", "op": "lt" }],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "id": 2, "title": "Cache Hits vs Misses (rate)", "type": "graph",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(avatar_cache_hits_total[1m])) by (cache_type)",
          "legendFormat": "{{cache_type}} hits"
        },
        {
          "expr": "sum(rate(avatar_cache_misses_total[1m])) by (cache_type)",
          "legendFormat": "{{cache_type}} misses"
        }
      ],
      "yaxes": [{ "format": "ops" }],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 3, "title": "Overall Hit Ratio", "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 4, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(avatar_cache_hits_total[5m])) / (sum(rate(avatar_cache_hits_total[5m])) + sum(rate(avatar_cache_misses_total[5m])))",
          "legendFormat": "hit ratio"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 0.5, "color": "yellow" }, { "value": 0.8, "color": "green" }] } } }
    },
    {
      "id": 4, "title": "Cache Activity Heatmap", "type": "heatmap",
      "gridPos": { "x": 4, "y": 8, "w": 20, "h": 6 },
      "targets": [
        {
          "expr": "sum(rate(avatar_cache_hits_total[5m])) by (cache_type)",
          "legendFormat": "{{cache_type}}"
        }
      ]
    }
  ]
}
