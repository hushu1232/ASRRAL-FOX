    "/api/pet/config": {
      "get": {
        "tags": ["宠物"],
        "summary": "获取桌面宠物配置",
        "description": "返回完整宠物配置（含解密后的 API 密钥）。无配置时自动创建默认配置。",
        "responses": {
          "200": { "description": "宠物配置（pet_name, personality, backstory, animation_model, idle_timeout, wander_interval, params, bodyParams, equippedParts, mappedAssets 等）" }
        }
      },
      "put": {
        "tags": ["宠物"],
        "summary": "更新桌面宠物配置",
        "description": "更新宠物的外观、行为等配置。",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "pet_name": { "type": "string", "minLength": 1 },
                  "personality": { "type": "string" },
                  "backstory": { "type": "string" },
                  "animation_model": { "type": "string", "enum": ["live2d", "dragonbones", "vrm"] },
                  "ffmpeg_path": { "type": "string" },
                  "idle_timeout": { "type": "number", "minimum": 0, "description": "闲置超时（秒），0=永不触发" },
                  "wander_interval": { "type": "number", "minimum": 0 },
                  "avatar_id": { "type": "string", "description": "关联的虚拟形象 ID" },
                  "model_path": { "type": "string" },
                  "params": { "type": "array", "items": { "type": "object", "properties": { "key": { "type": "string" }, "value": { "type": "number" } } } },
                  "body_params": { "type": "array", "items": { "type": "object", "properties": { "key": { "type": "string" }, "value": { "type": "number" } } } },
                  "equipped_parts": { "type": "array", "items": { "type": "object", "properties": { "slot": { "type": "string" }, "part_id": { "type": "string" } } } },
                  "material_overrides": { "type": "object" },
                  "mapped_assets": { "type": "array", "items": { "type": "object", "properties": { "slotName": { "type": "string" }, "assetId": { "type": "string" }, "assetType": { "type": "string", "enum": ["model", "texture", "animation", "sound"] } } } }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "配置已更新" }
        }
      }
    },
    "/api/pet/export": {
      "get": {
        "tags": ["宠物"],
        "summary": "导出宠物配置（Alife WebBridge 客户端合同）",
        "description": "返回蛇形命名 JSON，符合 Alife WebBridge 客户端预期的 PetConfigExport 模式。与 tests/schemas/pet-export-schema.json 保持一致。",
        "responses": {
          "200": { "description": "PetConfigExport JSON（version, petName, personality, backstory, animationModel, idleTimeout, wanderInterval, params, bodyParams, equippedParts, mappedAssets）" }
        }
      }
    },
    "/api/pet/assets": {
      "get": {
        "tags": ["宠物"],
        "summary": "获取可用资产列表",
        "parameters": [
          { "name": "type", "in": "query", "schema": { "type": "string", "enum": ["model", "texture", "animation", "sound"] } }
        ],
        "responses": {
