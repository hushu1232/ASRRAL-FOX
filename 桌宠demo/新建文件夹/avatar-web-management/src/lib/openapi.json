        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["assetId", "assetType", "slotName"],
                "properties": {
                  "assetId": { "type": "string" },
                  "assetType": { "type": "string", "enum": ["model", "texture", "animation", "sound"] },
                  "slotName": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "资产映射已创建" },
          "404": { "description": "宠物配置不存在" }
        }
      }
    },
    "/api/pet/set-avatar": {
      "post": {
        "tags": ["宠物"],
        "summary": "绑定形象到桌面宠物",
