        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 } },
          { "name": "pageSize", "in": "query", "schema": { "type": "integer", "default": 20 } }
        ],
        "responses": {
          "200": { "description": "OAuth 客户端列表" },
          "403": { "description": "权限不足" }
        }
      },
      "post": {
        "tags": ["管理后台"],
        "summary": "创建 OAuth 客户端",
        "description": "需要 admin 角色",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["clientName", "redirectUris"],
                "properties": {
                  "clientName": { "type": "string" },
                  "redirectUris": { "type": "array", "items": { "type": "string", "format": "uri" } },
                  "scopes": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "OAuth 客户端已创建，返回 clientId 和 clientSecret（仅此一次）" },
          "403": { "description": "权限不足" }
        }
      }
    },
    "/api/admin/oauth-clients/{id}": {
      "put": {
        "tags": ["管理后台"],
        "summary": "更新 OAuth 客户端",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "客户端已更新" },
          "403": { "description": "权限不足" }
        }
      },
      "delete": {
        "tags": ["管理后台"],
        "summary": "吊销 OAuth 客户端",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": {
          "200": { "description": "客户端已吊销" },
          "403": { "description": "权限不足" }
        }
      }
    },
    "/api/oauth/authorize": {
      "get": {
        "tags": ["OAuth 2.0"],
        "summary": "OAuth 授权端点",
        "description": "第三方应用授权入口。用户登录后展示权限确认页。",
        "parameters": [
          { "name": "client_id", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "redirect_uri", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "response_type", "in": "query", "schema": { "type": "string", "enum": ["code"] } },
          { "name": "scope", "in": "query", "schema": { "type": "string" } },
          { "name": "state", "in": "query", "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "权限确认页面" },
          "400": { "description": "参数无效" }
        }
      }
    },
    "/api/oauth/token": {
      "post": {
        "tags": ["OAuth 2.0"],
        "summary": "OAuth Token 端点",
        "description": "用授权码换取访问令牌。支持 PKCE。",
        "requestBody": {
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["grant_type", "code", "redirect_uri", "client_id"],
                "properties": {
                  "grant_type": { "type": "string", "enum": ["authorization_code", "refresh_token"] },
                  "code": { "type": "string" },
                  "redirect_uri": { "type": "string" },
                  "client_id": { "type": "string" },
                  "client_secret": { "type": "string" },
                  "code_verifier": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "access_token + refresh_token" },
          "400": { "description": "授权码无效或已过期" }
        }
      }
    },
    "/api/oauth/userinfo": {
      "get": {
        "tags": ["OAuth 2.0"],
        "summary": "OAuth UserInfo 端点",
        "description": "返回当前令牌持有者的用户信息（OpenID Connect 风格）",
        "responses": {
          "200": { "description": "用户信息（sub, email, username）" },
          "401": { "description": "令牌无效" }
        }
      }
    },
    "/api/metrics": {
      "get": {
        "tags": ["系统"],
        "summary": "Prometheus 指标端点",
        "description": "返回 Prometheus 文本格式的 HTTP 指标（请求计数、延迟直方图、速率限制等）。通过 podAnnotations 自动发现。",
        "security": [],
        "responses": {
          "200": { "description": "Prometheus text/plain 格式指标" }
        }
      }
    },
    "/api/health": {
      "get": {
        "tags": ["系统"],
        "summary": "健康检查",
        "security": [],
        "responses": {
          "200": { "description": "服务正常" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
