    "/api/pet/session": {
      "post": {
        "tags": ["宠物"],
        "summary": "桌面宠物会话生命周期",
        "description": "管理 Alife 桌面运行时的宠物会话：start 开始会话，update 更新交互计数/崩溃日志，end 结束会话",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["action"],
                "properties": {
                  "action": { "type": "string", "enum": ["start", "update", "end"] },
                  "sessionId": { "type": "string", "description": "update/end 时必填" },
                  "interactionCount": { "type": "integer", "description": "交互计数" },
                  "crashLog": { "type": "string", "description": "崩溃日志" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "会话已创建（start）" },
          "200": { "description": "会话已更新/已结束" },
          "400": { "description": "action 无效" }
        }
      }
    },
