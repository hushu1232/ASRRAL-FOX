      "firstName": "Alice",
      "lastName": "Wang",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice1234",
          "temporary": false
        }
      ]
    },
    {
      "username": "bob",
