{
  "name": "astralfox-market",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "jest --verbose --runInBand tests/unit src/components/__tests__",
    "test:integration": "jest --verbose --runInBand tests/*.test.ts tests/contracts/**/*.test.ts tests/contract/**/*.test.ts",
    "test:integration:local": "start-server-and-test \"npm run start\" http://localhost:3000 \"npm run test:integration\"",
    "test:all": "jest --verbose",
    "test:watch": "jest --watch --verbose",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "postinstall": "prisma generate",
    "test:e2e:api": "playwright test --project=chromium e2e/api.spec.ts",
    "test:visual": "jest --config tests/visual/jest.config.ts --verbose",
    "test:visual:update": "jest --config tests/visual/jest.config.ts --updateSnapshot --verbose",
    "test:e2e:ui": "playwright test e2e/cross-browser.spec.ts",
    "test:ci:e2e": "start-server-and-test \"npm run start\" http://localhost:3000 \"npm run test:e2e\"",
    "test:ci:e2e:api": "start-server-and-test \"npm run start\" http://localhost:3000 \"npm run test:e2e:api\"",
    "test:ci:unit": "jest --coverage --verbose tests/unit src/components/__tests__",
    "prepare": "cd .. && git config core.hooksPath .husky; husky",
    "analyze": "ANALYZE=true next build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.3",
    "@ant-design/nextjs-registry": "^1.3.0",
    "@gsap/react": "^2.1.2",
