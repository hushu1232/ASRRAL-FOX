    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@types/three": "^0.184.1",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "ajv-formats": "^1.6.1",
