    "start-server-and-test": "^3.0.5",
    "storybook": "^10.4.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.11",
    "tsx": "^4.20.0",
    "typescript": "^5"
  }
}
