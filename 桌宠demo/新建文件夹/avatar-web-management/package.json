    "@storybook/addon-viewport": "^9.0.8",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "antd": "^6.4.3",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
